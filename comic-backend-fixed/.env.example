# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# ─── Database ───
DB_URL=jdbc:mysql://localhost:3306/comic_db
DB_USERNAME=root
DB_PASSWORD=changeme

# ─── JWT ───
# FIX [01]: no fallback — app refuses to start if this is missing.
# Generate: openssl rand -base64 48  (must be >= 32 characters)
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-chars
JWT_EXPIRATION=86400000

# ─── Cookie ───
# FIX [03]: set false in local dev (HTTP), true in production (HTTPS)
APP_COOKIE_SECURE=false

# ─── Rate limiter ───
# FIX [05]: comma-separated IPs of your reverse-proxy/load-balancer.
# Leave empty if not behind a proxy (uses TCP remoteAddr directly).
TRUSTED_PROXIES=

# ─── Email ───
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENABLED=false

# ─── Frontend URL (CORS + sitemap + email links) ───
FRONTEND_URL=http://localhost:5173

# ─── OAuth2 (Google) ───
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# ─── Cloudinary (Image Uploads) ───
# Find these at: https://cloudinary.com/console → Settings → Upload
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset
